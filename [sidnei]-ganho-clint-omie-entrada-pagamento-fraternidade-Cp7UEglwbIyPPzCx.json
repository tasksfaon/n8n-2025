        "jsonBody": "{\n  \"call\": \"ListarContasCorrentes\",\n  \"app_key\": \"4712664620664\",\n  \"app_secret\": \"480d91ea67d601c5c261c014442fc810\",\n  \"param\": [\n    {\n      \"pagina\": 1,\n      \"registros_por_pagina\": 50\n    }\n  ]\n}\n",
