    {
      "parameters": {
        "jsCode": "// Obtém os dados do nó webhook\nconst items = $input.all();\n\nreturn items.map(item => {\n    // ===============================\n    // 1) TELEFONE (buyer_phone)\n    // ===============================\n    let phone = item.json.body?.buyer_phone || \"\";\n\n    // Remove caracteres especiais, mantendo apenas números\n    phone = String(phone).replace(/[^\\d]/g, \"\");\n\n    // Verifica se já está no formato 55DDDTelefone\n    const regex = /^55\\d{2}\\d{8,9}$/;\n\n    if (!regex.test(phone)) {\n        // Se tiver 10 ou 11 dígitos (DDD + telefone), adiciona 55\n        if (phone.length === 10 || phone.length === 11) {\n            phone = \"55\" + phone;\n        }\n    }\n\n    // ===============================\n    // 2) LOCAL (product_name)\n    // ===============================\n    const productName = item.json.body?.product_name || \"\";\n    let local = \"\";\n\n    if (productName.includes(\"->\")) {\n        local = productName.split(\"->\")[1].trim();\n    } else if (productName.includes(\"-\")) {\n        local = productName.split(\"-\").pop().trim();\n    }\n\n    // ===============================\n    // 3) RETORNO\n    // ===============================\n    return {\n        json: {\n            phone,\n            local\n        }\n    };\n});\n"
      },
