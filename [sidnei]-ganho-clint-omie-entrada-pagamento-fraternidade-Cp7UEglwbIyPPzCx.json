    {
      "parameters": {
        "jsCode": "// Função auxiliar para normalizar texto\nfunction normalizar(str) {\n  return str?.toString()\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, '') // remove acentos\n    .replace(/[^a-z0-9]/gi, ' ')     // remove caracteres especiais\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .toLowerCase();\n}\n\n// Dados do Edit Fields\nconst plataforma = normalizar($('Edit Fields').item.json['Plataforma de Pagamento']);\nconst polo = normalizar($('Edit Fields').item.json['Polo']);\nconst dono = normalizar($('Edit Fields').item.json['Dono']);\n\n// Dados dos nós HTTP\nconst contas = $('HTTP Conta Corrente').item.json.ListarContasCorrentes || [];\nconst categorias = $('HTTP Listar Categorias').item.json.categoria_cadastro || [];\nconst projetos = $('HTTP Listar Projeto').item.json.cadastro || [];\nconst vendedores = $('HTTP Listar Vendedor').item.json.cadastros || [];\n\n// Debug: logs úteis para entender o que está sendo comparado\nconsole.log('📌 Plataforma:', plataforma);\nconsole.log('📌 Polo:', polo);\nconsole.log('📌 Dono:', dono);\n\nconsole.log('🗂️ Projetos disponíveis:');\nprojetos.forEach(p => console.log('-', p.nome));\n\nconsole.log('🧑‍💼 Vendedores disponíveis:');\nvendedores.forEach(v => console.log('-', v.cNome));\n\n// 🔍 Conta corrente pela plataforma\nconst contaMatch = contas.find(conta =>\n  normalizar(conta.descricao).includes(plataforma)\n);\n\n// 🔍 Categoria pela palavra-chave \"Adesão Fraternidade\"\nconst categoriaMatch = categorias.find(cat =>\n  normalizar(cat.descricao).includes(\"adesao fraternidade\")\n);\n\n// 🔍 Projeto: compara se alguma palavra do polo está no nome do projeto\nconst projetoMatch = projetos.find(p => {\n  const nomeProjeto = normalizar(p.nome);\n  return polo.split(' ').some(palavra => nomeProjeto.includes(palavra));\n});\n\n\n// Retorno\nreturn [{\n  json: {\n    id_conta_corrente: contaMatch?.nCodCC || null,\n    codigo_categoria: categoriaMatch?.codigo || null,\n    codigo_projeto: projetoMatch?.codigo || null,\n    nome_projeto_encontrado: projetoMatch?.nome || null\n  }\n}];\n"
      },
