    {
      "parameters": {
        "jsCode": "// =========================\n// FUNÇÃO NORMALIZADORA\n// =========================\nconst norm = (s) =>\n  (s || \"\")\n    .toString()\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\")\n    .toLowerCase()\n    .replace(/\\s+/g, \" \")\n    .trim();\n\n\n// =========================\n// TELEFONE\n// =========================\nlet telefone = $json.body.convidado_telefone || \"\";\ntelefone = telefone.replace(/\\D/g, \"\");\n\n// Remove 55 se já vier com DDI\nif (telefone.startsWith(\"55\") && telefone.length > 11) {\n  telefone = telefone.substring(2);\n}\n\n// Se vier com 10 dígitos (DDD + número sem 9)\nif (telefone.length === 10) {\n  const ddd = telefone.substring(0, 2);\n  const numero = telefone.substring(2);\n  telefone = ddd + \"9\" + numero;\n}\n\n// Adiciona 55\nif (telefone.length === 11) {\n  telefone = \"55\" + telefone;\n}\n\n\n// =========================\n// MEMBRO + EMAIL\n// =========================\nlet nomeOriginal = $input.first().json.body.membro_nome || \"\";\nlet nomeKey = norm(nomeOriginal);\n\nlet email_membro = \"Não encontrado\";\n\n// Base oficial\nconst membros = {\n  \"kauan matheus\": \"kaua.caeclub@gmail.com\",\n  \"erika adm\": \"maria.victoria@caeclub.com.br\",\n  \"leticia piazzetta\": \"letty.piazzetta@gmail.com\",\n  \"caroline fernandes\": \"carolineprado2017@icloud.com\",\n  \"mateus laurentino\": \"mateusl.caeclub@gmail.com\",\n  \"alice theophilo pereira\": \"alicetheophilope@gmail.com\",\n  \"beatriz adriany\": \"biahadriany@gmail.com\",\n  \"jessica miranda\": \"contato@caesaopaulo.com.br\",\n  \"jonathan andre\": \"jonathanandrepires@gmail.com\",\n  \"heloiza ciocheti martins\": \"heloizaciocheti15@gmail.com\",\n  \"talita artacho\": \"talita.a.caeclub@gmail.com\",\n  \"beatriz foresto\": \"bia.caeclub@gmail.com\"\n};\n\n// =========================\n// ALIASES / VARIAÇÕES\n// =========================\nconst aliases = {\n  \"jonatan\": \"jonathan andre\",\n  \"jonathan\": \"jonathan andre\",\n  \"jonathan pires\": \"jonathan andre\",\n  \"kaua\": \"kauan matheus\",\n  \"erika\": \"erika adm\",\n  \"leticia\": \"leticia piazzetta\",\n  \"caroline\": \"caroline fernandes\",\n  \"mateus\": \"mateus laurentino\",\n  \"alice\": \"alice theophilo pereira\",\n  \"beatriz adriany\": \"beatriz adriany\",\n  \"beatriz foresto\": \"beatriz foresto\",\n  \"jessica\": \"jessica miranda\",\n  \"heloiza\": \"heloiza ciocheti martins\",\n  \"talita\": \"talita artacho\"\n};\n\n// Se for alias direto\nif (aliases[nomeKey]) {\n  nomeKey = aliases[nomeKey];\n}\n\n// =========================\n// MATCH EXATO\n// =========================\nif (membros[nomeKey]) {\n  email_membro = membros[nomeKey];\n}\n\n// =========================\n// MATCH PARCIAL (fallback)\n// =========================\nif (email_membro === \"Não encontrado\" && nomeKey) {\n  for (const nomeBase in membros) {\n    if (\n      nomeBase.includes(nomeKey) ||\n      nomeKey.includes(nomeBase)\n    ) {\n      email_membro = membros[nomeBase];\n      break;\n    }\n  }\n}\n\n\n// =========================\n// RETORNO\n// =========================\nreturn [\n  {\n    json: {\n      telefone_formatado: telefone,\n      membro_nome_detectado: nomeKey,\n      email_membro: email_membro\n    }\n  }\n];"
      },
