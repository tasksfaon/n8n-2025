    {
      "parameters": {
        "jsCode": "// =========================\n// FUNÇÃO NORMALIZADORA\n// =========================\nconst norm = (s) =>\n  (s || \"\")\n    .toString()\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\")\n    .toLowerCase()\n    .replace(/\\s+/g, \" \")\n    .trim();\n\n\n// =========================\n// TELEFONE\n// =========================\nlet telefone = $json.body.contact_phone || \"\";\ntelefone = telefone.replace(/\\D/g, \"\");\n\nif (telefone.startsWith(\"55\") && telefone.length > 11) {\n  telefone = telefone.substring(2);\n}\n\nif (telefone.length === 10) {\n  const ddd = telefone.substring(0, 2);\n  const numero = telefone.substring(2);\n  telefone = ddd + \"9\" + numero;\n}\n\nif (telefone.length === 11) {\n  telefone = \"55\" + telefone;\n}\n\n\n// =========================\n// MEMBRO\n// =========================\nlet nomeOriginal = $json.body.deal_user_name || \"\";\nlet nomeKey = norm(nomeOriginal);\n\nlet email_membro = \"Não encontrado\";\n\n\n// =========================\n// BASE MEMBROS\n// =========================\nconst membros = {\n  \"kauan matheus\": \"kaua.caeclub@gmail.com\",\n  \"erika adm\": \"maria.victoria@caeclub.com.br\",\n  \"leticia piazzetta\": \"letty.piazzetta@gmail.com\",\n  \"caroline fernandes\": \"carolineprado2017@icloud.com\",\n  \"mateus laurentino\": \"mateusl.caeclub@gmail.com\",\n  \"alice theophilo pereira\": \"alicetheophilope@gmail.com\",\n  \"beatriz adriany\": \"biahadriany@gmail.com\",\n  \"jessica miranda\": \"contato@caesaopaulo.com.br\",\n  \"jonathan andre\": \"jonathanandrepires@gmail.com\",\n  \"heloiza ciocheti martins\": \"heloizaciocheti15@gmail.com\",\n  \"talita artacho\": \"talita.a.caeclub@gmail.com\",\n  \"beatriz foresto\": \"bia.caeclub@gmail.com\"\n};\n\n\n// =========================\n// ALIASES\n// =========================\nconst aliases = {\n  \"jonatan\": \"jonathan andre\",\n  \"jonathan\": \"jonathan andre\",\n  \"jonathan pires\": \"jonathan andre\",\n  \"kaua\": \"kauan matheus\",\n  \"erika\": \"erika adm\",\n  \"leticia\": \"leticia piazzetta\",\n  \"caroline\": \"caroline fernandes\",\n  \"mateus\": \"mateus laurentino\",\n  \"alice\": \"alice theophilo pereira\",\n  \"jessica\": \"jessica miranda\",\n  \"heloiza\": \"heloiza ciocheti martins\",\n  \"talita\": \"talita artacho\"\n};\n\nif (aliases[nomeKey]) {\n  nomeKey = aliases[nomeKey];\n}\n\n\n// =========================\n// POLO (VINDO DO WEBHOOK)\n// =========================\nlet polos = $('Webhook').item.json.body.contact_interesse_polo || [];\n\nlet polosTexto = norm(polos.join(\" \"));\n\n\n// =========================\n// DETECÇÃO POR POLO\n// =========================\nconst regioesTalita = [\n  \"faria lima\",\n  \"osasco\",\n  \"grande abc\",\n  \"granja\",\n  \"lapa\",\n  \"campo belo\",\n  \"mooca\",\n  \"santo amaro\"\n];\n\nconst regioesMateus = [\n  \"butanta\",\n  \"vila maria\",\n  \"alphaville\",\n  \"tatuape\",\n  \"santos\"\n];\n\nif (regioesTalita.some(r => polosTexto.includes(r))) {\n  nomeKey = \"talita artacho\";\n}\n\nif (regioesMateus.some(r => polosTexto.includes(r))) {\n  nomeKey = \"mateus laurentino\";\n}\n\n\n// =========================\n// MATCH EXATO\n// =========================\nif (membros[nomeKey]) {\n  email_membro = membros[nomeKey];\n}\n\n\n// =========================\n// MATCH PARCIAL\n// =========================\nif (email_membro === \"Não encontrado\" && nomeKey) {\n  for (const nomeBase in membros) {\n    if (\n      nomeBase.includes(nomeKey) ||\n      nomeKey.includes(nomeBase)\n    ) {\n      email_membro = membros[nomeBase];\n      break;\n    }\n  }\n}\n\n\n// =========================\n// RETORNO\n// =========================\nreturn [\n  {\n    json: {\n      telefone_formatado: telefone,\n      membro_nome_detectado: nomeKey,\n      email_membro: email_membro,\n      polos_detectados: polosTexto\n    }\n  }\n];"
      },
