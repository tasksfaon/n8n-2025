      "parameters": {
        "jsCode": "// Acessa o telefone do caminho correto\nlet telefoneRaw = $input.first().json.body?.data?.buyer?.checkout_phone || '';\n\n// Remove todos os caracteres que não são dígitos\nlet telefoneLimpo = telefoneRaw.replace(/\\D/g, '');\n\n// Remove código do país duplicado se já estiver presente\nif (telefoneLimpo.length > 11 && telefoneLimpo.startsWith('55')) {\n  telefoneLimpo = telefoneLimpo.slice(2);\n} else if (telefoneLimpo.length > 11) {\n  telefoneLimpo = telefoneLimpo.slice(-11);\n}\n\n// Extrai DDD e número\nconst ddd = telefoneLimpo.slice(0, 2);\nconst numero = telefoneLimpo.slice(2);\n\n// Retorna no formato 55DDDTelefone\nconst telefoneFormatado = `55${ddd}${numero}`;\n\n// Acessa o valor do produto\nlet valorProduto =  $input.first().json.body.data.purchase.price.value|| 0;\n\n// Formata o valor no formato R$ XX,XX\nlet valorFormatado = `${Number(valorProduto).toFixed(2).replace('.', ',')}`;\n\n// Retorna o resultado\nreturn [\n  {\n    json: {\n      telefoneFormatado,\n      valorFormatado\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
