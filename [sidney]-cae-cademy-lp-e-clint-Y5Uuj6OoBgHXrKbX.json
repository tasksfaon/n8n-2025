      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Extrai nome e e-mail diretamente\nconst nome = body.input_text;\nconst email = body.email;\n\n// Formata telefone no padrão 55DDDTelefone\nlet telefone = body.phone || '';\ntelefone = telefone.replace(/\\D/g, ''); // Remove tudo que não for número\nif (telefone.startsWith('55')) {\n  telefone = telefone;\n} else if (telefone.length === 11) {\n  telefone = '55' + telefone;\n} else if (telefone.length === 13 && telefone.startsWith('550')) {\n  telefone = telefone.replace(/^550/, '55');\n}\n\nreturn [\n  {\n    json: {\n      nome: nome,\n      email: email,\n      telefone: telefone,\n    }\n  }\n];\n"
      },
