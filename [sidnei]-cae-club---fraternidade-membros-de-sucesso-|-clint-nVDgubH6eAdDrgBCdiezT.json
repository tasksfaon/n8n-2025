      "parameters": {
        "jsCode": "return items.map(item => {\n  // ===== TELEFONE =====\n  let telefone = item.json.body.contact_phone || '';\n  telefone = telefone.toString().replace(/\\D/g, '');\n\n  if (telefone.length === 11) {\n    telefone = '55' + telefone;\n  }\n\n  if (telefone.length === 12) {\n    telefone = telefone.slice(0, 4) + '9' + telefone.slice(4);\n  }\n\n  telefone = telefone.slice(0, 13);\n\n  // ===== FUNÇÕES AUX =====\n  const norm = (s) =>\n    (s || '')\n      .toString()\n      .normalize('NFD')\n      .replace(/[\\u0300-\\u036f]/g, '')\n      .toLowerCase()\n      .replace(/\\s+/g, ' ')\n      .trim();\n\n  // ===== POLO =====\n  const poloCompleto =\n    item.json.body.contact_polo ||\n    item.json.body.contact_interesse_polo ||\n    item.json.body.deal_polo ||\n    '';\n\n  let polo = poloCompleto.split(/polo/i).pop().trim();\n  let poloKey = norm(polo);\n\n  // ===== ALIASES =====\n  const aliases = {\n    alphavile: 'alphaville',\n    alpha: 'alphaville',\n    grandeabc: 'grande abc',\n    'granja viana': 'granja'\n  };\n\n  if (aliases[poloKey]) {\n    poloKey = aliases[poloKey];\n  }\n\n  // ===== DONO + EMAIL =====\n  let dono = 'Não definido';\n  let email_dono = '';\n\n  const mapaPolos = {\n    Talita: {\n      polos: [\n        'faria lima',\n        'osasco',\n        'grande abc',\n        'granja',\n        'lapa',\n        'campo belo',\n        'mooca',\n        'santo amaro'\n      ],\n      email: 'talita.a.caeclub@gmail.com'\n    },\n    Mateus: {\n      polos: [\n        'butanta',\n        'vila maria',\n        'alphaville',\n        'tatuape',\n        'santos'\n      ],\n      email: 'mateusl.caeclub@gmail.com'\n    }\n  };\n\n  // ===== MATCH EXATO =====\n  for (const nome in mapaPolos) {\n    if (mapaPolos[nome].polos.includes(poloKey)) {\n      dono = nome;\n      email_dono = mapaPolos[nome].email;\n      break;\n    }\n  }\n\n  // ===== MATCH PARCIAL =====\n  if (dono === 'Não definido' && poloKey) {\n    outer: for (const nome in mapaPolos) {\n      for (const poloMapa of mapaPolos[nome].polos) {\n        if (poloKey.includes(poloMapa) || poloMapa.includes(poloKey)) {\n          dono = nome;\n          email_dono = mapaPolos[nome].email;\n          break outer;\n        }\n      }\n    }\n  }\n\n  return {\n    json: {\n      telefone_padronizado: telefone,\n      polo: polo,\n      polo_key: poloKey,\n      dono: dono,\n      email_dono: email_dono,\n    },\n  };\n});"
      },
