      "parameters": {
        "jsCode": "const data = $input.item.json;\n\nconst fileName = `${data.name.replace(/\\s+/g, '-').toLowerCase()}-${data.id}.json`;\n\nreturn [\n  {\n    json: {\n      fileName\n    }\n  }\n];"
