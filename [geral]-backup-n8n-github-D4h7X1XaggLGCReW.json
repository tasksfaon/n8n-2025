      {
        "parameters": {
          "jsCode": "const items = $('Loop Over Items').all();\n\n// pega o item correspondente ao índice atual\nconst data = items[$itemIndex].json;\n\n// transforma JSON em string\nconst conteudo = JSON.stringify(data, null, 2);\n\n// nome do arquivo\nconst nome = typeof data.name === 'string' ? data.name : 'sem-nome';\nconst id = data.id ? String(data.id) : Date.now().toString();\n\nconst safeName = nome\n  .trim()\n  .replace(/\\s+/g, '-')\n  .replace(/[^a-zA-Z0-9-_]/g, '')\n  .toLowerCase();\n\nconst fileName = `${safeName}-${id}.json`;\n\nreturn [\n  {\n    json: {\n      fileName\n    },\n    binary: {\n      data: {\n        data: Buffer.from(conteudo).toString('base64'),\n        mimeType: 'application/json',\n        fileName\n      }\n    }\n  }\n];"
