              "name": "on_conflict",
              "value": "transaction_id"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "resolution=ignore-duplicates,return=minimal"
            },
            {
              "name": "Accept-Profile",
              "value": "public"
            },
            {
              "name": "Content-Profile",
              "value": "public"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"lead_id\": $(\"Buscar Lead por Email\").item.json.id || null, \"product_id\": $(\"Buscar Produto por Nome\").item.json.id || null, \"event_type\": \"compra_concluida\", \"platform\": $(\"Normalizar Checkout\").item.json.platform, \"transaction_id\": $(\"Normalizar Checkout\").item.json.transaction_id, \"amount_cents\": $(\"Normalizar Checkout\").item.json.amount_cents, \"currency\": \"BRL\", \"payment_method\": $(\"Normalizar Checkout\").item.json.payment_method, \"installments\": $(\"Normalizar Checkout\").item.json.installments, \"utm_source\": $(\"Normalizar Checkout\").item.json.utm_source, \"utm_medium\": $(\"Normalizar Checkout\").item.json.utm_medium, \"utm_campaign\": $(\"Normalizar Checkout\").item.json.utm_campaign, \"utm_content\": $(\"Normalizar Checkout\").item.json.utm_content, \"utm_term\": $(\"Normalizar Checkout\").item.json.utm_term, \"occurred_at\": $(\"Normalizar Checkout\").item.json.occurred_at } }}"
      }
    },
    {
      "id": "e0d87ef0-46dc-4482-a1d2-731dfff272aa",
      "name": "Buscar Produto por Nome",
