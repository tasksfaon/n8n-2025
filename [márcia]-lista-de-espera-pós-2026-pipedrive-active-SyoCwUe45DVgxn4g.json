      {
        "parameters": {
          "jsCode": "// ================================\n// 1. Captura do telefone\n// ================================\nconst telefoneOriginal = $input.first().json.data.phone[0].value || '';\n\n// ================================\n// 2. Remove tudo que não for número\n// ================================\nlet telefone = telefoneOriginal.replace(/\\D/g, '');\n\n// ================================\n// 3. Remove código do país (55), se existir\n// ================================\nif (telefone.startsWith('55')) {\n  telefone = telefone.substring(2);\n}\n\n// ================================\n// 4. Extrai DDD e número\n// ================================\nconst ddd = telefone.substring(0, 2);\nlet numero = telefone.substring(2);\n\n// ================================\n// 5. Garante o dígito 9 (celular)\n// ================================\nif (numero.length === 8) {\n  numero = '9' + numero;\n}\n\n// ================================\n// 6. Monta telefone padronizado\n// ================================\nconst telefonePadronizado = `55${ddd}${numero}`;\n\n// ================================\n// 7. Captura o código da UF vindo do Pipedrive\n// ================================\nconst codigoUF = $input.first().json.data['f77f5009ce48d7b62427c2d0961522f1830eb66e'];\n\n// ================================\n// 8. Mapa código → UF\n// ================================\nconst mapaUF = {\n  6050: \"AC\",\n  6051: \"AL\",\n  6052: \"AP\",\n  6053: \"AM\",\n  6054: \"BA\",\n  6055: \"CE\",\n  6056: \"DF\",\n  6057: \"ES\",\n  6058: \"GO\",\n  6059: \"MA\",\n  6060: \"MT\",\n  6061: \"MS\",\n  6062: \"MG\",\n  6063: \"PA\",\n  6064: \"PB\",\n  6065: \"PR\",\n  6066: \"PE\",\n  6067: \"PI\",\n  6068: \"RJ\",\n  6069: \"RN\",\n  6070: \"RS\",\n  6071: \"RO\",\n  6072: \"RR\",\n  6073: \"SC\",\n  6074: \"SP\",\n  6075: \"SE\",\n  6076: \"TO\"\n};\n\n// ================================\n// 9. Resolve a UF\n// ================================\nconst uf = mapaUF[codigoUF] || \"\";\n\n// ================================\n// 10. Retorno\n// ================================\nreturn {\n  ddd,\n  telefonePadronizado,\n  uf\n};\n"
        },
