          "jsonBody": "={\n  \"apiKey\": \"37e290c1-7110-4353-8f4f-b74f5057e915\",\n  \"phoneNumber\": \"{{ $json.Telefone }}\",\n  \"name\": \"{{ $json['Primeiro Nome'] }}\"\n}",
