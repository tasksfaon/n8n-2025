      "typeVersion": 3,
      "position": [
        220,
        100
      ],
      "parameters": {
        "resource": "file",
        "operation": "download",
        "fileId": {
          "__rl": true,
          "mode": "id",
          "value": "1JVTcdDrU1AEowE5P5iyx92NUJUCk4PwBBR1VrTyWeU0"
        },
        "options": {
          "binaryPropertyName": "data",
          "googleFileConversion": {
            "conversion": {
              "sheetsToFormat": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
            }
          },
          "fileName": "cadastros.xlsx"
        }
      }
    },
    {
      "id": "3f488260-1eed-4d88-a3f7-e95c30fb5c7e",
