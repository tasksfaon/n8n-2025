    {
      "id": "da16d712-a624-4d4a-90b0-6cd1a13cb74a",
      "name": "Upsert Cadastros no Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        940,
        100
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $(\"Configurar Credenciais\").item.json.supabaseUrl }}/rest/v1/cadastros",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "specifyHeaders": "keypair",
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $(\"Configurar Credenciais\").item.json.supabaseKey }}"
            },
            {
              "name": "Prefer",
              "value": "resolution=merge-duplicates,return=minimal"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{ $input.all().map(i => ({ id_cadastro: i.json.id_cadastro, nome: i.json.nome, email: i.json.email, telefone: i.json.telefone, data_cadastro: i.json.data_cadastro, uid_mh: i.json.uid_mh, utm_source: i.json.utm_source, utm_medium: i.json.utm_medium, utm_campaign: i.json.utm_campaign, utm_term: i.json.utm_term, utm_content: i.json.utm_content, lp_venda: i.json.lp_venda })) }}"
      }
