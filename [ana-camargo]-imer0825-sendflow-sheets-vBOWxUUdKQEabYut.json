    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\n// Tenta buscar o telefone em múltiplos caminhos possíveis\nconst rawPhone = String(data.data?.number || data.body?.data?.number || '');\n\n// Remove tudo que não for número\nlet cleaned = rawPhone.replace(/\\D/g, '');\n\n// Formata no padrão 55DDDNúmero\nif (cleaned.length === 11) {\n  cleaned = '55' + cleaned;\n} else if (\n  (cleaned.length === 13 && cleaned.startsWith('55')) ||\n  (cleaned.length === 12 && cleaned.startsWith('55'))\n) {\n  // já está certo ou quase certo\n} else if (cleaned.length === 12 && !cleaned.startsWith('55')) {\n  cleaned = '55' + cleaned;\n} else {\n  cleaned = '';\n}\n\nreturn [{\n  json: {\n    telefoneFormatado: cleaned,\n    original: rawPhone\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
